{
  "manifest_version": 3,
  "name": "HearSay – Course pronunciation assistant",
  "version": "0.1.0",
  "description": "Pull text from the page you're viewing, preview screen-reader speech, and manage class pronunciation dictionaries.",
  "minimum_chrome_version": "116",
  "permissions": ["activeTab", "scripting", "sidePanel", "tabs", "downloads"],
  "host_permissions": ["https://*.supabase.co/*", "https://*/*", "http://*/*"],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Open HearSay side panel"
  },
  "side_panel": {
    "default_path": "src/sidepanel.html"
  }
}
