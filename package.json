{
  "name": "hearsay",
  "version": "0.1.0",
  "private": true,
  "description": "HearSay — authoring assistant that helps course authors make Canvas content pronounceable by screen readers without requiring students to edit personal dictionaries.",
  "type": "module",
  "scripts": {
    "test": "node --test test/*.test.mjs",
    "build:dict": "node tools/build-dictionary.mjs",
    "build:doc": "node tools/build-test-doc.mjs",
    "build:vendor": "node tools/build-vendor.mjs",
    "serve": "node tools/build-vendor.mjs && node tools/serve.mjs 8123",
    "push:dict": "node tools/push-dictionary-to-supabase.mjs",
    "pull:dict": "node tools/pull-dictionary-from-supabase.mjs",
    "sync:dict": "node tools/sync-combined-dictionary.mjs",
    "pack:extension": "node tools/build-vendor.mjs && node tools/pack-extension.mjs",
    "build:pages": "node tools/build-vendor.mjs && node tools/build-pages.mjs",
    "build:user-guide": "node tools/build-vendor.mjs && node tools/build-user-guide.mjs"
  },
  "license": "MIT",
  "devDependencies": {
    "esbuild": "^0.25.0",
    "jspdf": "^2.5.2",
    "jszip": "^3.10.1"
  }
}
